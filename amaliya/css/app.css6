@keyframes spin-cw-1turn {
  0% {
    transform: rotate(-1turn); }
  100% {
    transform: rotate(0); } }

.spin-ccw {
  animation-name: spin-cw-1turn; }

@keyframes spin-cw-1turn {
  0% {
    transform: rotate(0); }
  100% {
    transform: rotate(1turn); } }

.wiggle {
  animation-name: wiggle-7deg; }

@keyframes wiggle-7deg {
  40%, 50%, 60% {
    transform: rotate(7deg); }
  35%, 45%, 55%, 65% {
    transform: rotate(-7deg); }
  0%, 30%, 70%, 100% {
    transform: rotate(0); } }

.shake,
.spin-cw,
.spin-ccw,
.wiggle {
  animation-duration: 500ms; }

.infinite {
  animation-iteration-count: infinite; }

.slow {
  animation-duration: 750ms !important; }

.fast {
  animation-duration: 250ms !important; }

.linear {
  animation-timing-function: linear !important; }

.ease {
  animation-timing-function: ease !important; }

.ease-in {
  animation-timing-function: ease-in !important; }

.ease-out {
  animation-timing-function: ease-out !important; }

.ease-in-out {
  animation-timing-function: ease-in-out !important; }

.bounce-in {
  animation-timing-function: cubic-bezier(0.485, 0.155, 0.24, 1.245) !important; }

.bounce-out {
  animation-timing-function: cubic-bezier(0.485, 0.155, 0.515, 0.845) !important; }

.bounce-in-out {
  animation-timing-function: cubic-bezier(0.76, -0.245, 0.24, 1.245) !important; }

.short-delay {
  animation-delay: 300ms !important; }

.long-delay {
  animation-delay: 700ms !important; }

.top-bar-left,
.top-bar-right {
  width: 100%; }

#qLtempOverlay {
  background: #fff !important; }

.queryloader__overlay__bar, .queryloader__overlay__percentage {
  margin-top: 0 !important;
  top: 0 !important; }

.queryloader__overlay__bar {
  height: 3px !important; }

.queryloader__overlay__percentage {
  display: none;
  margin-top: 8px !important;
  font-size: 12px !important;
  font-weight: 600; }

._breakpoint {
  position: absolute;
  top: 0; }

.stream {
  max-width: 100%;
  overflow-x: hidden;
  position: relative; }

.frame {
  text-align: center;
  margin: auto;
  position: absolute;
  width: 100%; }
  .frame .columns {
    text-align: left; }
  .frame h2 {
    font-family: 'ProximaNova',sans-serif; }

.flower {
  margin: auto; }

.news-block {
  z-index: 2; }
  .news-block header {
    text-transform: uppercase;
    margin-bottom: 40px; }
    .news-block header a {
      color: #a47940;
      font-weight: 600;
      display: inline-block;
      line-height: 1em; }
  .news-block .post-body {
    font-family: Merriweather, Georgia, serif; }

.news-container {
  background: rgba(251, 172, 0, 0.11);
  padding: 70px 0; }

body {
  padding-top: 62px;
  overflow: hidden; }
  body.ready {
    overflow-y: auto; }
  body > footer {
    text-align: center; }
    body > footer .menu {
      text-align: center; }
      body > footer .menu li {
        display: block; }
  body.page-main footer#footer {
    width: 100%;
    position: absolute; }

a {
  transition: color .7s; }
  a.active, a:focus {
    outline: none; }

h2 {
  color: #a47940;
  text-transform: uppercase;
  font-size: 52px;
  font-weight: 600;
  margin: 0;
  line-height: 1em; }

h4 {
  font-size: 14px;
  font-weight: bold;
  margin: 0;
  text-transform: uppercase; }

h6.circle-title {
  text-align: center;
  text-transform: uppercase;
  color: #774808;
  font-weight: 800;
  font-size: 200px;
  opacity: 0.9;
  line-height: 143px; }
  h6.circle-title.sub {
    font-size: 60px;
    line-height: 54px;
    letter-spacing: 12px; }
    h6.circle-title.sub + h6 {
      font-size: 110px;
      line-height: 82px; }

.nav {
  list-style: none;
  margin: 0;
  padding: 0;
  font-size: 14px;
  text-align: left; }
  .nav li {
    padding: 0;
    margin: 0;
    text-transform: uppercase;
    font-weight: bold; }

.title {
  margin: auto;
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  mix-blend-mode: multiply; }

.top-bar {
  position: fixed;
  z-index: 1001;
  background-color: rgba(255, 255, 255, 0.82);
  right: 0;
  left: 0;
  top: 0;
  padding-top: 13px;
  padding-bottom: 13px; }
  .top-bar .menu {
    background: none; }
    .top-bar .menu li a {
      padding: 0.75rem 0.5rem; }
    .top-bar .menu li.menu-logo > a {
      padding-top: 8px;
      padding-bottom: 8px; }
  .top-bar button:focus {
    outline: 0; }

.menu li {
  letter-spacing: 0.1em; }
  .menu li a {
    text-transform: uppercase;
    font-weight: 800;
    font-size: 12px;
    color: #262626; }
    .menu li a:hover, .menu li a.active {
      color: #a67f07; }
  .menu li.current-menu-item a {
    color: #a67f07; }

.menu h5 {
  font-size: 14px;
  text-transform: uppercase;
  font-weight: 800;
  color: #a67f07;
  margin-bottom: 5px; }

.menu-logo img {
  width: 109px; }

.menu-sub .menu.nested {
  margin-left: 0;
  margin-bottom: 20px; }

.menu-sub > li a {
  font-weight: 600;
  padding: 0;
  margin: 0;
  font-size: 12px;
  line-height: 1.6em; }

.nav p {
  margin-bottom: 0; }

.scrollmagic-pin-spacer {
  -ms-transform: none;
      transform: none; }

body {
  height: calc(2050vh + 400px); }

#footer {
  top: calc(2050vh + 400px);
  position: absolute;
  width: 100%; }

._breakpoint {
  right: 0;
