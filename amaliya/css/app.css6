/*
frames
*/
#amalia {
  top: 0;
  left: 0;
  right: 0;
  height: calc(100vh - 128px);
  position: fixed;
  background: no-repeat center center;
  background-size: 100% auto;
  width: auto;
  max-width: 70%;
  margin: auto; }

#first {
  top: calc(100vh - 250px); }

#news {
  top: calc(200vh);
  margin-top: 40px;
  margin-bottom: 40px; }

#red {
  top: calc(250vh + 600px);
  text-align: left;
  width: auto;
  margin-left: 0;
  z-index: -1; }

#concept {
  top: calc(400vh + 600px);
  left: 0;
  right: 0;
  width: 318px;
  margin: auto; }
  #concept .flower {
    height: auto; }

#concept-menu {
  top: calc(450vh + 600px); }

#book {
  top: calc(700vh + 600px); }

#book-title {
  top: calc(800vh + 600px);
  left: 0;
  right: 0;
  margin: auto; }
  #book-title .flower {
    height: auto; }

#book-menu {
  top: calc(900vh + 600px); }

#gold {
  top: calc(970vh + 600px);
  width: auto;
  right: 0; }
  #gold .flower {
    left: auto;
    right: 0; }

#white {
  top: calc(1100vh + 600px); }

#translations {
  top: calc(1200vh + 600px);
  left: 0;
  right: 0;
  margin: auto; }
  #translations .flower {
    height: auto; }

#translations-menu {
  top: calc(1250vh + 600px); }

#gold2 {
  top: calc(1550vh + 600px); }

#gold2-title {
  top: calc(1660vh + 600px);
  left: 0;
  right: 0;
  margin: auto; }
  #gold2-title .flower {
    height: auto; }

#gold2-menu {
  top: calc(1730vh + 600px); }

#pink {
  top: calc(1850vh + 600px);
  width: auto;
  margin-left: 0;
  z-index: -1; }

#m-amalia {
  max-width: 50%;
  margin: 5vh auto; }

#m-red {
  margin-top: -32%;
  margin-left: -70%; }

#m-book {
  margin-top: 5vh; }

#m-gold {
  margin-top: -22%;
  margin-right: -70%; }

#mobile {
  display: none;
  text-align: center; }

/*
end frames
*/
@media screen and (max-width: 40em) {
  #responsive-menu {
    -ms-flex: none;
        flex: none;
    width: 100%; }
  .menu li {
    display: block;
    width: 100%; } }

